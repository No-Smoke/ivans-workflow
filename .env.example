# IWO Environment Configuration
# Copy to .env and edit for your machine. All values have sensible defaults.
# See iwo/config.py for the full list of options.
#
# .env is gitignored — never commit secrets to the repo.

# ─── Required: Target Project ───────────────────────────────────
# Absolute path to the project IWO orchestrates (the repo with docs/agent-comms/).
# No default — IWO will fall back to current working directory if not set.
IWO_PROJECT_ROOT=/path/to/your/project

# ─── Paths ──────────────────────────────────────────────────────
# Where IWO writes agent logs. Default: {IWO repo}/logs
# IWO_LOG_DIR=/path/to/logs

# Directory containing agent skills (ops-action-resolver, credential-manager, etc.).
# Default: {IWO repo}/skills — bundled skills ship with the repo.
# Override to point at a custom skills directory.
# IWO_SKILLS_DIR=/path/to/custom/skills

# ─── tmux ───────────────────────────────────────────────────────
# Name of the tmux session hosting the agents.
# IWO_TMUX_SESSION=claude-agents

# ─── Memory Services (optional) ─────────────────────────────────
# IWO stores pipeline telemetry to Qdrant + Neo4j. If these are not
# reachable, IWO degrades gracefully — orchestration works fine without them.
# Set IWO_ENABLE_MEMORY=false to skip all memory integration.
# IWO_ENABLE_MEMORY=true

# Qdrant vector database
# IWO_QDRANT_URL=http://localhost:6333
# IWO_QDRANT_API_KEY=

# Neo4j graph database
# IWO_NEO4J_URI=bolt://localhost:7687
# IWO_NEO4J_USER=neo4j
# IWO_NEO4J_PASSWORD=

# Ollama embedding service (used for Qdrant vector generation)
# IWO_OLLAMA_URL=http://localhost:11434
# IWO_OLLAMA_MODEL=mxbai-embed-large

# ─── Notifications ──────────────────────────────────────────────
# ntfy.sh push notifications (mobile). Leave topic empty to disable.
# IWO_NTFY_TOPIC=my-project-topic
# IWO_NTFY_SERVER=https://ntfy.sh

# Webhook URL for n8n or similar (optional)
# IWO_WEBHOOK_URL=

# ─── Health Checks ──────────────────────────────────────────────
# Comma-separated URLs to check after deploy. Leave empty to skip.
# IWO_HEALTH_CHECK_URLS=https://myapp.com/api/health

# ─── Deploy Gates ────────────────────────────────────────────────
# auto_approve_safe_deploys: auto-approve when handoff declares no infra changes
# auto_deploy_all: bypass ALL deploy gates (for overnight runs)
# auto_continue: auto-queue next-spec when pipeline completes
# IWO_AUTO_APPROVE_SAFE_DEPLOYS=true
# IWO_AUTO_DEPLOY_ALL=false
# IWO_AUTO_CONTINUE=false
